{
  "name": "@graphiquestor/macro-intelligence",
  "version": "1.0.0",
  "description": "GraphiQuestor MCP server — institutional macro intelligence for AI agents",
  "type": "module",
  "bin": {
    "graphiquestor-mcp": "./dist/index.js"
  },
