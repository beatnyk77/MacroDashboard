{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "lib": [
            "ESNext",
            "deno.ns",
            "deno.window"
        ],
        "strict": true,
        "noEmit": true,
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "baseUrl": ".",
        "paths": {
            "@supabase/supabase-js": [
                "https://esm.sh/@supabase/supabase-js@2.39.8"
            ],
            "@std/assert": [
                "https://deno.land/std@0.211.0/assert/mod.ts"
            ],
            "@shared/*": [
                "./_shared/*"
            ]
        }
    },
    "include": [
        "./**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}